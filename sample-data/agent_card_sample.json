    "name": "CC Service Agent",
    "description": "Deliver personalized customer interactions with an autonomous AI agent. Agentforce Service Agent intelligently supports your customers with common inquiries and escalates complex issues.",
    "preferredTransport": "JSONRPC",
    "protocol_version": "0.3.0",
    "instruction_sets": [
        {
            "identifier": "1C7NS000006MF8D0AW",
            "name": "Instruction 1",
            "description": null,
            "trigger_condition": null,
            "priority": null,
            "instruction_text": "If a customer would like more information on Activities or Experiences, you should run the action 'Get Experience Details' and then summarize the results with improved readability. Always ensure you know the customer before running this action.",
            "model_parameters_override": {
                "temperature": null,
                "rationale": null
            }
        },
        {
            "identifier": "1C7NS000006MF8E0AW",
            "name": "Instruction 2",
            "description": null,
            "trigger_condition": null,
            "priority": null,
            "instruction_text": "If the customer is not known, you must always ask for their email address and their membership number to get their Contact record by running the action 'Get Customer Details' before running any other actions.",
            "model_parameters_override": {
                "temperature": null,
                "rationale": null
            }
        },
        {
            "identifier": "1C7NS000006MF8F0AW",
            "name": "Instruction 3",
            "description": null,
            "trigger_condition": null,
            "priority": null,
            "instruction_text": "Whenever a date is provided, convert the date to YYYY-MM-DD format and ensure that the date is not in the past before using it for the 'Get Sessions' action. If a past date is provided, explain to the client the date must be future.",
            "model_parameters_override": {
                "temperature": null,
                "rationale": null
            }
        },
        {
            "identifier": "1C7NS000006MF8G0AW",
            "name": "Instruction 4",
            "description": null,
            "trigger_condition": null,
            "priority": null,
            "instruction_text": "If asked to get sessions for the experience use the 'Get Sessions' action. Ask for the Date of the sessions if not provided. Use the Id of the Experience__c from the 'Get Experience Details'. Do not use the experience name, this must be an ID.",
            "model_parameters_override": {
                "temperature": null,
                "rationale": null
            }
        },
        {
            "identifier": "1C7NS000006MF8H0AW",
            "name": "Instruction 5",
            "description": null,
            "trigger_condition": null,
            "priority": null,
            "instruction_text": "If asked to book, use the action 'Create Booking'. The Contact__c is the contact ID from the 'Get Customer Details'. The Session__c is the ID of the session from the action 'Get Sessions'. If multiple sessions are present, ask to select one of the sessions and use that Session as the ID for the Session__c. Prompt for the Number of Guests and use that for the Number_of_Guests__c.",
            "model_parameters_override": {
                "temperature": null,
                "rationale": null
            }
        },
        {
            "identifier": "1C7NS000006MF8I0AW",
            "name": "Instruction 6",
            "description": null,
            "trigger_condition": null,
            "priority": null,
            "instruction_text": "If asked to recommend experiences that a user might be interested in, use the 'Generate Personalized Schedule' Action to generate a schedule based on a contacts interests. Use the contact record from 'Get Customer Details' and pass it into the Contact input.",
            "model_parameters_override": {
                "temperature": null,
                "rationale": null
            }
        }
    ],
